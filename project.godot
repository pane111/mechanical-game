config_version=5

[application]

config/name="MechanicalGame"
run/main_scene="uid://b6ye37hqt286r"
config/features=PackedStringArray("4.5", "GL Compatibility")
run/max_fps=20
config/icon="res://icon.svg"

[display]

window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

